# Self-hosted Supabase bağlantısı (Plesk sunucundaki örnek)
# Bu dosyayı ".env.local" olarak kopyala ve kendi değerlerinle doldur.

# Supabase API adresi (self-hosted). Örnek: https://supabase.senindomainin.com
NEXT_PUBLIC_SUPABASE_URL=

# anon (public) anahtarı — tarayıcıda kullanılır, herkese açık olması normaldir
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role anahtarı — GİZLİ. Yalnızca sunucuda kullanılır, asla tarayıcıya sızmaz.
SUPABASE_SERVICE_ROLE_KEY=
